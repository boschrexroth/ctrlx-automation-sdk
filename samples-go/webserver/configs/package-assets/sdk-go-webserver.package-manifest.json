{
  "$schema": "https://json-schema.boschrexroth.com/ctrlx-automation/ctrlx-core/apps/package-manifest/package-manifest.v1.6.schema.json",
  "version": "1.0.0",
  "id": "sdk-go-webserver",
  "services": {
    "proxyMapping": [
      {
        "name": "sdk-go-webserver",
        "url": "/sdk-go-webserver/",
        "binding": "unix://{$SNAP_DATA}/package-run/sdk-go-webserver/web.sock",
        "restricted": []
      }
    ]
  },
  "menus": {
    "sidebar": [
      {
        "id": "sdk-webserver",
        "title": "SDK webserver",
        "icon": "bosch-ic-worldwideweb",
        "items": [
          {
            "id": "sdk-go-webserver-blank",
            "title": "SDK go webserver (New Tab)",
            "target": "_blank",
            "link": "/sdk-go-webserver/",
            "items": []
          },
          {
            "id": "sdk-go-webserver-embedded",
            "title": "SDK go webserver (Embedded)",
            "target": "embedded",
            "link": "/sdk-go-webserver/",
            "items": []
          }
        ]
      }
    ],
    "settings": [],
    "overview": [
      {
        "id": "sdk-go-webserver",
        "target": "_blank",
        "title": "SDK go webserver",
        "icon": "bosch-ic-worldwideweb",
        "link": "/sdk-go-webserver/"
      }
    ]
  }
}