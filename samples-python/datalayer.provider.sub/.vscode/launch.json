    "version": "0.2.0",
    "configurations": [
        {
            "name": "Provider",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/app/provider.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {"PYTHONPATH": "${workspaceFolder}:${PYTHONPATH}" },
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Client",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/app/client.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {"PYTHONPATH": "${workspaceFolder}:${PYTHONPATH}" },
            "cwd": "${workspaceFolder}"
        }        
    ]
}